{
  "name": "braidr",
  "version": "1.5.175",
  "description": "A tool for managing multiple POV character outlines with independent timeline views",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && npm run build:electron && electron .",
    "build": "npm run build:vite && npm run build:electron",
    "build:vite": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "package": "npm run build && electron-builder",
    "cap:build": "npm run build:vite && npx cap sync",
    "cap:open": "npx cap open ios",
    "cap:run": "npx cap run ios",
    "test": "node scripts/run-tests.cjs",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "lint": "eslint src",
    "check": "npm run typecheck && npm run lint",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "keywords": [
    "novel",
    "writing",
    "outliner",
    "pov",
    "timeline"
  ],
  "author": "Brian",
  "license": "MIT",
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3-force": "^3.0.10",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20.19.30",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "electron-rebuild": "^3.2.9",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "@blocknote/core": "^0.51.4",
    "@blocknote/mantine": "^0.51.4",
    "@blocknote/react": "^0.51.4",
    "@blocknote/xl-multi-column": "^0.51.4",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/preferences": "^8.0.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/dom": "^1.7.5",
    "@tiptap/extension-image": "^3.19.0",
    "@tiptap/extension-placeholder": "^3.16.0",
    "@tiptap/extension-table": "^3.19.0",
    "@tiptap/extension-table-cell": "^3.19.0",
    "@tiptap/extension-table-header": "^3.19.0",
    "@tiptap/extension-table-row": "^3.19.0",
    "@tiptap/extension-task-item": "^3.19.0",
    "@tiptap/extension-task-list": "^3.19.0",
    "@tiptap/extension-typography": "^3.16.0",
    "@tiptap/react": "^3.16.0",
    "@tiptap/starter-kit": "^3.16.0",
    "@tiptap/suggestion": "^3.19.0",
    "better-sqlite3": "^12.10.0",
    "d3-force": "^3.0.0",
    "docx": "^9.5.1",
    "electron-updater": "^6.7.3",
    "electron-window-state": "^5.0.3",
    "file-saver": "^2.0.5",
    "posthog-node": "^5.24.15",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "tippy.js": "^6.3.7"
  },
  "build": {
    "appId": "com.brian.braidr",
    "productName": "Braidr",
    "icon": "build/icon.png",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    },
    "afterSign": "scripts/notarize.js",
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Utility",
      "target": [
        "AppImage"
      ]
    },
    "npmRebuild": true,
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/better-sqlite3/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "theMurfinator",
      "repo": "braidr"
    }
  }
}
